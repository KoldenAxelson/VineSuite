APP_NAME=VineSuite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Logging ─────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vinesuite
DB_USERNAME=vinesuite
DB_PASSWORD=secret

# ─── Database (Test — separate PostgreSQL instance) ──────────────
DB_TEST_HOST=postgres-test
DB_TEST_PORT=5432
DB_TEST_DATABASE=vinesuite_test
DB_TEST_USERNAME=vinesuite
DB_TEST_PASSWORD=secret

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache ───────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=vinesuite_cache

# ─── Session ─────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Queue ───────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─── Mail (Mailpit for local dev) ────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@vinesuite.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Meilisearch ─────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=vinesuite-dev-key

# ─── Stripe (fill in from https://dashboard.stripe.com/test/apikeys) ─
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=usd

# ─── Sanctum ─────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:8000

# ─── Horizon ─────────────────────────────────────────────────────
HORIZON_PREFIX=vinesuite_horizon:

# ─── Tenancy ─────────────────────────────────────────────────────
# Central domains (management portal, API)
TENANCY_CENTRAL_DOMAINS=localhost
