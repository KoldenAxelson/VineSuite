APP_NAME=VineSuite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vinesuite
DB_USERNAME=vinesuite
DB_PASSWORD=secret

# ─── Session ─────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting / Filesystem / Queue ───────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ─── Cache ───────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=vinesuite_cache

# ─── Redis ───────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail (Mailpit) ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@vinesuite.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Meilisearch ─────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=vinesuite-dev-key

# ─── Stripe (fill in from dashboard.stripe.com/test/apikeys) ────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=usd

# ─── Sanctum ─────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:8000

# ─── Horizon ─────────────────────────────────────────────────────
HORIZON_PREFIX=vinesuite_horizon:

# ─── Tenancy ─────────────────────────────────────────────────────
TENANCY_CENTRAL_DOMAINS=localhost

VITE_APP_NAME="${APP_NAME}"
