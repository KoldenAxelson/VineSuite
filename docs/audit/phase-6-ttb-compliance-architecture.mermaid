---
title: "Phase 6 — TTB & Regulatory Compliance Layer Architecture"
---
graph TB
    subgraph EventLog["Immutable Event Log (Source of Truth)"]
        direction LR
        E1[lot_created]
        E2[blend_finalized]
        E3[stock_received]
        E4[bottling_completed]
        E5[stock_sold]
        E6[transfer_executed]
        E7[rack_completed]
        E8[filtering_logged]
        E9[addition_created]
        E10[sweetening_completed]
        E11[fortification_completed]
        E12[amelioration_completed]
        E13[evaporation_measured]
        E14[breakage_reported]
        E15[wine_transferred_bonded]
    end

    subgraph WineClassification["Wine Type Classification (CBMA)"]
        WTC[WineTypeClassifier]
        LA[LabAnalysis Records]
        LA -->|most recent alcohol %| WTC
        WTC -->|"≤16% → col a"| COL_A["(a) Not Over 16%"]
        WTC -->|">16-21% → col b"| COL_B["(b) Over 16-21%"]
        WTC -->|">21-24% → col c"| COL_C["(c) Over 21-24%"]
        WTC -->|"payload → col d"| COL_D["(d) Artificially Carbonated"]
        WTC -->|"payload → col e"| COL_E["(e) Sparkling"]
        WTC -->|"payload → col f"| COL_F["(f) Hard Cider"]
        WTC -->|"no lab data"| COL_DEFAULT["(a) + needs_review"]
    end

    subgraph TTBEngine["TTB Report Generation Engine"]
        direction TB
        P2["PartTwoCalculator<br/>Wine Produced (Lines 2-6)<br/>5 production methods"]
        P3["PartThreeCalculator<br/>Wine Received (Lines 7-10)<br/>4 receipt types"]
        P4["PartFourCalculator<br/>Wine Removed<br/>Sec A (Lines 13-24) + Sec B (Lines 2-17)<br/>13 removal categories"]
        P5["PartFiveCalculator<br/>Losses (Lines 29-30)<br/>5 loss types"]
        P1["PartOneCalculator<br/>Section A Balance (Lines 1,12,31,32)<br/>Section B Balance (Lines 1,7,20,21)"]

        P2 & P3 & P4 & P5 --> P1
    end

    subgraph TTBOrchestration["Report Orchestration"]
        GEN[TTBReportGenerator]
        JOB[GenerateMonthlyTTBReportJob]
        JOB -->|"dispatches"| GEN
        GEN -->|"coordinates"| P2 & P3 & P4 & P5
        GEN -->|"computes balance"| P1
    end

    subgraph TTBStorage["Report Storage"]
        RPT["TTBReport Model<br/>UUID PK, JSONB data<br/>section_a + section_b"]
        RPT_LINES["TTBReportLine Model<br/>section, line_number, wine_type, gallons"]
        RPT -->|hasMany| RPT_LINES
    end

    subgraph TTBOutput["Report Output"]
        PDF["TTBReportPdfGenerator<br/>DomPDF → Form 5120.17<br/>6 wine type columns"]
        UI["ReviewTTBReport Page<br/>Section A/B summaries<br/>Drill-down, Approve"]
        RPT --> PDF
        RPT --> UI
    end

    E1 & E2 & E10 & E11 & E12 -->|production events| P2
    E3 -->|receipt events| P3
    E4 & E5 & E14 & E15 -->|removal events| P4
    E6 & E7 & E8 & E13 -->|loss events| P5
    WTC -.->|classifies lots| P2 & P3 & P4 & P5
    GEN -->|creates| RPT

    subgraph LicenseTracking["Bond & Permit Tracking"]
        LIC[License Model<br/>type, jurisdiction, expiry]
        LIC_JOB[LicenseExpirationReminderJob<br/>daily check]
        LIC_UI[LicenseResource<br/>Filament CRUD]
        LIC_JOB -->|"scans"| LIC
        LIC_UI -->|"manages"| LIC
    end

    subgraph DTCCompliance["DTC Shipping Compliance"]
        DTC_RULES[DTCComplianceRule<br/>50 states + DC]
        DTC_SHIP[CustomerDTCShipment<br/>shipment log]
        DTC_SVC[DTCComplianceService]
        DTC_SVC -->|"checks limits"| DTC_RULES
        DTC_SVC -->|"queries annual totals"| DTC_SHIP
        DTC_SVC -->|"records"| DTC_SHIP
    end

    subgraph LotTrace["Lot Traceability"]
        TRACE[LotTraceabilityService]
        TRACE_UI[LotTraceability Page]
        TRACE -->|"backward: sources"| E1 & E2
        TRACE -->|"forward: destinations"| E2 & E4 & E5
        TRACE_UI -->|"invokes"| TRACE
    end

    subgraph CertCompliance["Certification Compliance (Advisory)"]
        CERT[CertificationComplianceService]
        WP[WineryProfile.certification_types]
        CERT -->|"checks against"| WP
        E9 -.->|"addition events"| CERT
    end

    style WTC fill:#4caf50,stroke:#2e7d32,color:#000
    style COL_A fill:#e3f2fd,stroke:#1565c0,color:#000
    style COL_B fill:#fff3e0,stroke:#e65100,color:#000
    style COL_C fill:#fce4ec,stroke:#c62828,color:#000
    style COL_D fill:#f3e5f5,stroke:#6a1b9a,color:#000
    style COL_E fill:#e8f5e9,stroke:#2e7d32,color:#000
    style COL_F fill:#fff8e1,stroke:#f57f17,color:#000
