graph TB
    subgraph Sources["Payment Sources"]
        OnlineCheckout["Online Checkout<br/>(Stripe.js)"]
        POSCard["POS Card Present<br/>(Stripe Terminal)"]
        POSCash["POS Cash"]
        ClubCharge["Club Batch Charge<br/>(stored card)"]
        WidgetCheckout["Widget Checkout<br/>(Stripe.js)"]
    end

    subgraph Processing["Payment Processing (Stripe via Cashier)"]
        Cashier["Laravel Cashier<br/>charge() / refund() / subscribe()"]
        Connect["Stripe Connect<br/>Platform fee auto-deducted"]
        Terminal["Stripe Terminal<br/>Card-present SDK"]
    end

    subgraph Recording["Recording"]
        Event["Event Log<br/>payment_captured"]
        Order["Order + Payment records"]
        Inventory["Inventory deduction"]
    end

    OnlineCheckout --> Cashier
    ClubCharge --> Cashier
    WidgetCheckout --> Cashier
    POSCard --> Terminal
    Terminal --> Cashier
    POSCash --> Event

    Cashier --> Connect
    Connect --> Event
    Event --> Order
    Order --> Inventory

    %% Future: PaymentProcessor interface to abstract
    %% Square/Braintree as BYO options for Pro+ tiers
